# Normalise line endings to LF in the repo; checkout as-is on all platforms
* text=auto eol=lf
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary — never touch line endings
*.mp4 binary
*.png binary
*.pt binary
*.pth binary
